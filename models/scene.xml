<mujoco model="kinova_allegro_scene">
  <include file="kinova_allegro.xml"/>

  <statistic center="0.3 0 0.6" extent="1.0" meansize="0.05"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.15 0.15 0.15" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="rack_metal" rgba="0.35 0.35 0.4 1" specular="0.5" shininess="0.3"/>
    <material name="cable_tray" rgba="0.25 0.25 0.3 0.8"/>
    <material name="target_obj" rgba="0.2 0.7 0.3 1"/>
  </asset>

  <worldbody>
    <light pos="0.5 0 1.5" directional="true"/>
    <light pos="-0.5 0.5 1.0" directional="false" diffuse="0.3 0.3 0.3"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- ==================== SERVER RACK OBSTACLE ENVIRONMENT ==================== -->
    <!-- The rack is in front of the robot, offset along +X.
         Arm must reach into the gaps between shelves, rails, and cables. -->

    <!-- Rack frame: four vertical posts -->
    <body name="rack" pos="0.55 0 0.5">
      <!-- Left-front post -->
      <geom name="post_lf" class="obstacle" type="box" size="0.015 0.015 0.4"
        pos="-0.2 0.25 0" material="rack_metal"/>
      <!-- Right-front post -->
      <geom name="post_rf" class="obstacle" type="box" size="0.015 0.015 0.4"
        pos="-0.2 -0.25 0" material="rack_metal"/>
      <!-- Left-rear post -->
      <geom name="post_lr" class="obstacle" type="box" size="0.015 0.015 0.4"
        pos="0.2 0.25 0" material="rack_metal"/>
      <!-- Right-rear post -->
      <geom name="post_rr" class="obstacle" type="box" size="0.015 0.015 0.4"
        pos="0.2 -0.25 0" material="rack_metal"/>

      <!-- Horizontal shelf rails (cross-members the arm must avoid) -->
      <!-- Bottom shelf -->
      <geom name="shelf_bottom" class="obstacle" type="box" size="0.2 0.25 0.01"
        pos="0 0 -0.25" material="rack_metal"/>
      <!-- Middle shelf -->
      <geom name="shelf_mid" class="obstacle" type="box" size="0.2 0.25 0.01"
        pos="0 0 0.05" material="rack_metal"/>
      <!-- Top shelf -->
      <geom name="shelf_top" class="obstacle" type="box" size="0.2 0.25 0.01"
        pos="0 0 0.3" material="rack_metal"/>

      <!-- Cable tray running along the left side -->
      <geom name="cable_tray_1" class="obstacle" type="box" size="0.18 0.02 0.03"
        pos="0 0.2 -0.1" material="cable_tray"/>
      <!-- Horizontal pipe/conduit -->
      <geom name="conduit_1" class="obstacle" type="cylinder" size="0.015 0.22"
        pos="0 0 0.15" quat="1 1 0 0" material="cable_tray"/>
      <!-- Another cable bundle -->
      <geom name="cable_bundle" class="obstacle" type="cylinder" size="0.02 0.15"
        pos="0.1 -0.15 -0.05" quat="0.707 0 0.707 0" material="cable_tray"/>

      <!-- Target object to grasp (a small box sitting on the middle shelf) -->
      <body name="target_object" pos="0.05 0 0.07">
        <geom name="target" type="box" size="0.025 0.02 0.02"
          material="target_obj" contype="8" conaffinity="8" mass="0.1"/>
      </body>
    </body>
  </worldbody>
</mujoco>